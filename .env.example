# .env.example
# This file shows the environment variables used by the project.
# It is only an example file, so it should not contain private secrets.

# Name of the project
PROJECT_NAME=E-Commerce Conversion Intelligence Platform

# Environment name: local, docker, production, etc.
APP_ENV=local

# Path where the trained machine learning model will be saved
MODEL_PATH=models/trained/full_model_pipeline.joblib

# Port used later for Prometheus metrics
METRICS_PORT=8000

# Grafana local administrator account
# Copy this file to .env and replace the password before starting Docker Compose.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-local-password
